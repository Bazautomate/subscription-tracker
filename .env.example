# Copy this file to .env and fill in real values.

# Discord: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=

# Your Discord user ID, to @-mention you in reminders. Leave blank for no mention.
# (Discord -> Settings -> Advanced -> Developer Mode, then right-click yourself -> Copy User ID)
DISCORD_USER_ID=

# Email (example uses Gmail; requires an "app password", not your normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_TO=

# Hour (0-23, server local time) the daily renewal check runs
NOTIFY_CHECK_HOUR=9

# HTTP basic auth for the web UI. Leave BASIC_AUTH_USER blank to disable (e.g. local dev).
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
