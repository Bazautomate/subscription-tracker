# Copy this file to .env and fill in real values.

# Discord: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=

# Email (example uses Gmail; requires an "app password", not your normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_TO=

# Hour (0-23, server local time) the daily renewal check runs
NOTIFY_CHECK_HOUR=9
